# 값뚝 서버 환경변수 (.env.example)
# 이 파일을 .env로 복사한 뒤 실제 값을 채우세요.

# --- 필수 ---
DATABASE_URL=postgresql://user:password@localhost:5432/gapttuk_dev
JWT_SECRET=change-me-to-at-least-32-characters-long-secret

# --- 서버 ---
APP_ENV=dev
HOST=0.0.0.0
PORT=8080

# --- JWT ---
JWT_ACCESS_TTL_SECS=1800
JWT_REFRESH_TTL_SECS=604800

# --- 쿠팡파트너스 (승인 후 입력) ---
# COUPANG_ACCESS_KEY=
# COUPANG_SECRET_KEY=

# --- 네이버 검색 API (M5) ---
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# --- 소셜 로그인 ---
# KAKAO_REST_API_KEY=
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=

# --- 푸시 ---
# APNS_KEY_PATH=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# FCM_SERVICE_ACCOUNT=

# --- 모니터링 ---
# SENTRY_DSN=
