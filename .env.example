# ============================================================
# 값뚝(gapttuk) Server — 환경변수
# ============================================================
# 이 파일을 .env로 복사한 뒤 값을 채워주세요:
#   cp .env.example .env
#
# [필수] 표시된 변수는 반드시 설정해야 합니다.
# [선택] 표시된 변수는 미설정 시 해당 기능이 비활성화됩니다.
# ============================================================

# --- [필수] 서버 ---
APP_ENV=dev                          # dev | test | prod
HOST=0.0.0.0
PORT=8080

# --- [필수] 데이터베이스 ---
DATABASE_URL=postgres://glovis:gapttuk_dev_pw@localhost:5432/gapttuk
POSTGRES_PASSWORD=gapttuk_dev_pw     # docker-compose 전용

# --- [필수] JWT ---
# prod 환경: 최소 32자, "change-me" 포함 금지
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_TTL_SECS=1800             # Access token 만료: 30분
JWT_REFRESH_TTL_SECS=604800          # Refresh token 만료: 7일

# --- [선택] 소셜 로그인 ---
KAKAO_REST_API_KEY=
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# --- [선택] 크롤링 API ---
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- [선택] 푸시 알림 ---
APNS_KEY_PATH=                       # APNs P8 키 파일 경로
APNS_KEY_ID=
APNS_TEAM_ID=
FCM_SERVICE_ACCOUNT=                 # Firebase 서비스 계정 JSON 경로

# --- [선택] CORS ---
# 쉼표로 구분, 미설정 시 dev에서 전체 허용
ALLOWED_ORIGINS=

# --- [선택] 모니터링 ---
SENTRY_DSN=

# --- [선택] 로깅 ---
RUST_LOG=gapttuk_server=info,tower_http=info
